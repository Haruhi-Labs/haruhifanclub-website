# ============================================================
# haruhifanclub 统一后端环境变量模板
#
# 用法：
#   本地 dev：  cp deploy/env.sample .env       （从仓库根跑 cargo run，经 dotenvy 自动加载）
#   一键生成：  bash deploy/gen-secrets.sh       （自动填好 JWT/Cookie 密钥与超管口令到 .env）
#   生产：      拷到 /etc/haruhifanclub.env 并 chmod 600（由 systemd EnvironmentFile 注入）
#
# 格式约定（重要，关系到能否启动）：本文件对 dotenvy 与 systemd EnvironmentFile **两种加载都安全**——
#   · 注释一律独立成行：systemd 只把“行首 # / ;”当注释，不剥离“行内注释”，
#     形如 `KEY=value   # 说明` 会把整段算进值里（HARUHI_BIND 会因此解析失败、服务起不来）。
#   · 不要写 `export`，不要给值加 shell 引号（systemd 按字面处理，引号会进入值）。
# 所有 change-me 占位必须在生产替换；关键密钥缺失时 release 构建拒绝启动。
# ============================================================

# ---------- 服务 ----------
# Rust 后端监听地址
HARUHI_BIND=127.0.0.1:17777
# SQLite 库目录（core.db + 各模块 .db）
HARUHI_DATA_DIR=./data
# 上传根目录（按模块子目录）
HARUHI_UPLOADS_DIR=./uploads
# tracing 日志级别
RUST_LOG=info,haruhi=debug

# ---------- 鉴权（RBAC 单点登录）----------
# JWT 签名密钥（release 必填，≥32 位随机；可用 `openssl rand -hex 32` 生成）
HARUHI_JWT_SECRET=change-me-to-a-long-random-secret
# 令牌有效期（秒）
HARUHI_JWT_TTL_SECONDS=86400
# CORS 允许来源（逗号分隔；release 生效，留空则默认仅 PUBLIC_SITE_URL）。同源部署可不填。
HARUHI_CORS_ORIGINS=https://haruyuki.cn
# 首次启动 seed 超级管理员（仅当 core.db 无用户时生效）
HARUHI_SUPERADMIN_USER=admin
HARUHI_SUPERADMIN_PASSWORD=change-me-strong-password

# ---------- AI 内容审核（阿里云 DashScope，OpenAI 兼容）----------
# 留空则 AI 审核降级为离线放行（fail-open）
DASHSCOPE_API_KEY=
AI_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_TEXT_MODEL=qwen-plus
AI_IMAGE_MODEL=qwen-vl-plus

# ---------- art 模块：匿名 Cookie 签名 ----------
# release 必填；可用 `openssl rand -hex 32` 生成
ART_COOKIE_SECRET=change-me-art-cookie-secret

# ---------- shop 模块：邮件通知 ----------
# 包邮门槛（元）
SHOP_FREE_SHIPPING_THRESHOLD=150
# 是否启用邮件
MAIL_ENABLED=false
# 邮件驱动：resend | smtp | auto
MAIL_PROVIDER=auto
MAIL_FROM_NAME=春日商城
MAIL_FROM_ADDRESS=
MAIL_REPLY_TO=
# 站点公开地址（也用作 CORS 默认来源与邮件中的链接）
PUBLIC_SITE_URL=https://haruyuki.cn
# --- Resend ---
RESEND_API_KEY=
RESEND_API_BASE_URL=https://api.resend.com
# --- SMTP ---
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=

# ---------- download 模块：语雀资源站索引（/download）----------
# 语雀 API Token（X-Auth-Token）。留空则资源站后台同步不启动、前端拿空索引并提示未接入。
HARUHI_YUQUE_TOKEN=
# 语雀知识库 namespace（login/slug）；默认「凉宫春日资源站」
HARUHI_YUQUE_REPO=staff-sqlmik/phgf5z
# 后台同步间隔（秒），默认 6 小时
HARUHI_YUQUE_SYNC_INTERVAL_SECS=21600
