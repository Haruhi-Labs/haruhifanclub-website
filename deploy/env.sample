# ============================================================
# haruhifanclub 统一后端环境变量模板
# 用法：cp deploy/env.sample .env  然后填写
# 所有默认密钥必须在生产环境替换；缺失关键项时服务拒绝启动。
# ============================================================

# --- 服务 ---
HARUHI_BIND=127.0.0.1:8080          # Rust 后端监听地址
HARUHI_DATA_DIR=./data              # SQLite 库目录（core.db + 各模块 .db）
HARUHI_UPLOADS_DIR=./uploads        # 上传根目录（按模块子目录）
RUST_LOG=info,haruhi=debug          # tracing 日志级别

# --- 鉴权（RBAC 单点登录）---
HARUHI_JWT_SECRET=change-me-to-a-long-random-secret   # JWT 签名密钥（必填，生产务必更换）
HARUHI_JWT_TTL_SECONDS=86400                          # 令牌有效期（秒）
# 首次启动 seed 超级管理员（仅当 core.db 无用户时生效）
HARUHI_SUPERADMIN_USER=admin
HARUHI_SUPERADMIN_PASSWORD=change-me-strong-password

# --- AI 内容审核（阿里云 DashScope，OpenAI 兼容）---
DASHSCOPE_API_KEY=                  # 留空则 AI 审核降级为离线放行
AI_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_TEXT_MODEL=qwen-plus
AI_IMAGE_MODEL=qwen-vl-plus

# --- art 模块：匿名 Cookie 签名 ---
ART_COOKIE_SECRET=change-me-art-cookie-secret

# --- shop 模块：邮件通知 ---
SHOP_FREE_SHIPPING_THRESHOLD=150    # 包邮门槛（元）
MAIL_ENABLED=false                  # 是否启用邮件
MAIL_PROVIDER=auto                  # resend | smtp | auto
MAIL_FROM_NAME=春日商城
MAIL_FROM_ADDRESS=
MAIL_REPLY_TO=
PUBLIC_SITE_URL=https://haruyuki.cn
# Resend
RESEND_API_KEY=
RESEND_API_BASE_URL=https://api.resend.com
# SMTP
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
