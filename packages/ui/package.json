{
  "name": "@haruhi/ui",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Vue wrappers for SOS / Parallel Design System primitives.",
  "main": "src/index.js",
  "module": "src/index.js",
  "types": "src/index.d.ts",
  "scripts": {
    "lint": "eslint . --max-warnings=0",
    "typecheck": "vue-tsc --noEmit"
  },
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js"
    },
    "./components": {
      "types": "./src/components/index.d.ts",
      "import": "./src/components/index.js"
    }
  },
  "dependencies": {
    "@haruhi/design-system": "workspace:*"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "typescript": "~5.6.3",
    "vue-tsc": "^2.2.0"
  }
}
